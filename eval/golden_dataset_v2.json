  {
    "id": "GD-001",
    "scenario": "clear_approve_excellent_profile",
    "description": "High credit score, low utilization, no fraud signals — unambiguous APPROVE",
    "tier": "approve",
    "application": {
      "name": "Applicant A",
      "creditScore": 790,
      "utilization": 18.0,
      "addressMismatch": false,
      "delinquencies": 0,
      "annualIncome": 95000,
      "channel": "WEB"
    },
    "expected": {
      "credit_agent": { "riskLevel": "LOW", "score_max": 0.25 },
      "fraud_agent":  { "fraudRisk": "LOW", "recommendAction": "PROCEED" },
      "policy_rag_agent": { "action": "APPROVE" },
      "risk_decision_agent": { "recommendation": "APPROVE", "confidence_min": 0.65 },
      "explainability_agent": {
        "adverse_action_codes_expected": [],
        "summary_must_not_contain": ["decline", "manual review", "concern"]
      }
    }
  },

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ai-orchestrator-group
KAFKA_TOPIC_APPLICATION_RECEIVED=application.received
KAFKA_TOPIC_DLQ=application.dlq

# LLM provider — ollama | groq | openai | azure  (default: ollama)
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama

# Ollama — local LLM server (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest              # or llama3.1:70b if you have 32GB+ RAM
OLLAMA_EMBED_MODEL=nomic-embed-text    # best local embedding model for RAG

# Groq (LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama3-8b-8192            # or mixtral-8x7b-32768, llama3-70b-8192

# OpenAI (LLM_PROVIDER=openai or EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Azure OpenAI (LLM_PROVIDER=azure or EMBED_PROVIDER=azure)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_EMBED_DEPLOYMENT=text-embedding-3-small

# PostgreSQL — matches docker-compose service (user:password@host:port/db)
DATABASE_URL=postgresql+asyncpg://poc:poc@localhost:5432/decisions

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=policy_docs

# Policy documents path
POLICY_DOCS_PATH=../policy-documents

# LangSmith tracing (optional — comment out to disable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-key-here
# LANGCHAIN_PROJECT=credit-card-poc

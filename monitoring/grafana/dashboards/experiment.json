        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"champion\",recommendation=\"MANUAL_REVIEW\"}",
          "legendFormat": "MANUAL_REVIEW",

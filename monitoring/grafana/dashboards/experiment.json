        "barWidth": 0.5,
        "groupWidth": 0.7,
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "orientation": "auto",
        "stacking": "none",
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "Challenger — Recommendation Distribution",
      "type": "bargauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"challenger\",recommendation=\"APPROVE\"}",
          "legendFormat": "APPROVE",
          "refId": "A"

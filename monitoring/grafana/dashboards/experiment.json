        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"challenger\",recommendation=\"DECLINE\"}",
          "legendFormat": "DECLINE",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"challenger\",recommendation=\"MANUAL_REVIEW\"}",
          "legendFormat": "MANUAL_REVIEW",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "id": 5,
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "title": "Approve Rate Over Time — Champion vs Challenger",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"champion\",recommendation=\"APPROVE\"} / ignoring(recommendation) sum without(recommendation)(experiment_variant_decisions{variant=\"champion\"})",
          "legendFormat": "Champion APPROVE rate",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "experiment_variant_decisions{variant=\"challenger\",recommendation=\"APPROVE\"} / ignoring(recommendation) sum without(recommendation)(experiment_variant_decisions{variant=\"challenger\"})",
          "legendFormat": "Challenger APPROVE rate",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}}
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 20},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Auto-Promotions Triggered",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(experiment_promotion_triggered_total) or vector(0)",
          "legendFormat": "Promotions",
          "refId": "A"
        }
      ]
    }
